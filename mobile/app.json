{
  "expo": {
    "name": "Decoriyans",
    "slug": "decoriyans",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "decoriyans",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2e1c14"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.decoriyans.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2e1c14"
      },
      "package": "com.decoriyans.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://decoriyans.com"
    }
  }
}
